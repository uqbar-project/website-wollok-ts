describe "Tests de menuCrearHighscore" {
    test "iniciar desactiva reinicio y activa highscoreMngr" {
        menuCrearHighscore.reiniciarAtributos()
        menuCrearHighscore.iniciar()
        assert.equals(0, menuCrearHighscore.letrasIngresadas())
        assert.equals(false, menuCrearHighscore.desactivarEditor())
    }

    test "sumarletraIngresada incrementa letrasIngresadas" {
        menuCrearHighscore.reiniciarAtributos()
        menuCrearHighscore.sumarletraIngresada()
        assert.equals(1, menuCrearHighscore.letrasIngresadas())
    }

    
}


describe "Tests de FichaHighscore" {
    test "puntajeString devuelve string con offset" {
        const ficha = new FichaHighscore(inA="A", inB="B", inC="C", puntajeNum=123)
        assert.equals("1123", ficha.puntajeString())
    }

    test "acceso a iniciales y puntaje" {
        const ficha = new FichaHighscore(inA="X", inB="Y", inC="Z", puntajeNum=999)
        assert.equals("X", ficha.inA())
        assert.equals("Y", ficha.inB())
        assert.equals("Z", ficha.inC())
        assert.equals(999, ficha.puntajeNumero())
    }

    test "FichaHighscore.puntajeString lanza excepción si puntajeNum es nulo" {
        assert.throwsException({
            const ficha = new FichaHighscore(inA="A", inB="B", inC="C", puntajeNum=null)
            ficha.puntajeString()
        })
    }
}

describe "Tests de menuListaHighscores" {
    test "ingresar agrega un record" {
        const ficha = new FichaHighscore(inA="A", inB="B", inC="C", puntajeNum=100)
        menuListaHighscores.ingresar(ficha)
        assert.that(menuListaHighscores.records().contains(ficha))
    }

    test "ordenarHighscores ordena por puntaje" {
        menuListaHighscores.records().clear()
        const ficha1 = new FichaHighscore(inA="A", inB="B", inC="C", puntajeNum=200)
        const ficha2 = new FichaHighscore(inA="D", inB="E", inC="F", puntajeNum=300)
        menuListaHighscores.ingresar(ficha1)
        menuListaHighscores.ingresar(ficha2)
        menuListaHighscores.ordenarHighscores()
        assert.equals(ficha2, menuListaHighscores.listaHighscoresOrdenada().get(0))
    }

    test "mejoresCuatro devuelve hasta cuatro records" {
        menuListaHighscores.listaHighscoresOrdenada().clear()
        menuListaHighscores.listaHighscoresOrdenada().add(new FichaHighscore(inA="A", inB="B", inC="C", puntajeNum=1))
        menuListaHighscores.listaHighscoresOrdenada().add(new FichaHighscore(inA="D", inB="E", inC="F", puntajeNum=2))
        menuListaHighscores.listaHighscoresOrdenada().add(new FichaHighscore(inA="G", inB="H", inC="I", puntajeNum=3))
        menuListaHighscores.listaHighscoresOrdenada().add(new FichaHighscore(inA="J", inB="K", inC="L", puntajeNum=4))
        menuListaHighscores.listaHighscoresOrdenada().add(new FichaHighscore(inA="M", inB="N", inC="O", puntajeNum=5))
        assert.equals(4, menuListaHighscores.mejoresCuatro().size())
    }

}
describe "Tests de highscoreMngr" {
    test "iniciar agrega visual y activa teclado" {
        highscoreMngr.iniciar()
        assert.that(game.hasVisual(highscoreMngr))
        assert.equals(true, highscoreMngr.keyboardActivo())
    }

    test "desactivarEditor quita visual y reinicia atributos" {
        highscoreMngr.iniciar()
        highscoreMngr.desactivarEditor()
        assert.notThat(game.hasVisual(highscoreMngr))
        assert.equals(false, highscoreMngr.keyboardActivo())
    }

    test "plasmarPuntaje agrega los tres dígitos" {
        highscoreMngr.puntajesPlasmados().clear()
        highscoreMngr.plasmarPuntaje(123, game.at(3,3))
        assert.equals(3, highscoreMngr.puntajesPlasmados().size())
    }
    test "pasarAlSiguenteCaracter mueve la posición" {
        highscoreMngr.iniciar()
        const posAntes = highscoreMngr.position()
        highscoreMngr.pasarAlSiguenteCaracter()
        assert.notEquals(posAntes, highscoreMngr.position())
        highscoreMngr.desactivar()
    }
     test "destruirPlasmados limpia visuales y arrays" {
        highscoreMngr.iniciar()
        highscoreMngr.registrarLetra()
        highscoreMngr.plasmarPuntaje(123, game.at(3,3))
        highscoreMngr.destruirPlasmados()
        assert.equals(0, highscoreMngr.letrasPlasmadas().size())
        assert.equals(0, highscoreMngr.puntajesPlasmados().size())
        highscoreMngr.desactivar()
    }
    test "registrarLetra lanza excepción si no hay letra seleccionada" {
        assert.throwsException({
            highscoreMngr.inicialesActuales.clear()
            highscoreMngr.registrarLetra()
        })
    }

    
    
}

describe "Tests de visualNoHighscore" {
    test "iniciar agrega visual y desactivar lo quita" {
        visualNoHighscore.iniciar()
        assert.that(game.hasVisual(visualNoHighscore))
        visualNoHighscore.desactivar()
        assert.notThat(game.hasVisual(visualNoHighscore))
    }

    test "getters devuelven valores correctos" {
        assert.equals("NoRec.png", visualNoHighscore.image())
        assert.equals(game.at(0,0), visualNoHighscore.position())
    }
}
