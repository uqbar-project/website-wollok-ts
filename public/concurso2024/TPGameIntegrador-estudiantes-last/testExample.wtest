import gameManager.*
import general.*
import tableroYCartas.*
import interfaz.*
import sonidosGlobales.*
import controladores.*
import highscores.*

describe "Tests de gameManager" {
    test "paresTotales y tipoDeJuego iniciales" {
        gameManager.reiniciarAtributos()
        assert.equals(1, gameManager.paresTotales())
        assert.that(gameManager.tipoDeJuego())
    }

    test "sumarParEncontrado incrementa paresEncontrados" {
        gameManager.reiniciarAtributos()
        gameManager.sumarParEncontrado()
        assert.equals(1, gameManager.paresEncontrados())
    }

    test "cambiar tipo de juego y pares totales al iniciar juego" {
        gameManager.inicioDelJuego(5,false)
        assert.equals(5, gameManager.paresTotales())
        assert.notThat(gameManager.tipoDeJuego())
        assert.that(gameManager.juegoIniciado())
    }

    test "reiniciarAtributos deja los valores iniciales" {
        gameManager.inicioDelJuego(5, false)
        gameManager.reiniciarAtributos()
        assert.equals(1, gameManager.paresTotales())
        assert.equals(0, gameManager.paresEncontrados())
        assert.that(gameManager.tipoDeJuego())
        assert.notThat(gameManager.juegoIniciado())
    }

    test "inicioDelJuego setea atributos correctamente" {
        gameManager.reiniciarAtributos()
        gameManager.inicioDelJuego(7, false)
        assert.equals(7, gameManager.paresTotales())
        assert.notThat(gameManager.tipoDeJuego())
        assert.that(gameManager.juegoIniciado())
    }

    test "reiniciarTodo resetea todos los atributos y llama iniciar" {
        gameManager.inicioDelJuego(4, false)
        gameManager.iniciar()
        gameManager.reiniciarTodo()
        assert.equals(1, gameManager.paresTotales())
        assert.equals(0, gameManager.paresEncontrados())
        assert.that(gameManager.tipoDeJuego())
        assert.notThat(gameManager.juegoIniciado()) 
    }

}

describe "Tests de cursor" {
    test "iniciar activa el teclado" {
        cursor.iniciar()
        assert.equals(true, cursor.keyboardActivo())
    }

    test "paralizar y reanudar acción" {
        cursor.paralizarAccion()
        assert.equals(false, cursor.permitirAccion())
        cursor.reanudarAccion()
        assert.equals(true, cursor.permitirAccion())
    }

}

describe "Tests de comparador" {
    test "procesarCarta cambia tengoUnaCarta" {
        const cartaMock = new CartaDibujo(id=1)
        comparador.procesarCarta(cartaMock)
        assert.equals(true, comparador.tengoUnaCarta())
    }

    test "reiniciarAtributos deja valores iniciales" {
        comparador.primerCarta() == 1
        comparador.segundaCarta() == 2
        comparador.tengoUnaCarta() 
        comparador.reiniciarAtributos()
        assert.equals(null, comparador.primerCarta())
        assert.equals(null, comparador.segundaCarta())
        assert.equals(false, comparador.tengoUnaCarta())
    }
    test "comparador lanza excepción si procesa carta nula" {
        assert.throwsException({comparador.procesarCarta(null)})
    }
}

describe "Tests de puntuacionMngr" {
    test "sumar y restar puntos funcionan correctamente" {
        puntuacionMngr.reiniciarAtributos()
        puntuacionMngr.sumarPuntos()
        assert.that(puntuacionMngr.puntos() > 0)
        puntuacionMngr.restarPuntos()
        assert.notThat(puntuacionMngr.puntos() < 0)
    }

    test "restarPuntos no deja puntos negativos" {
        puntuacionMngr.reiniciarAtributos()
        puntuacionMngr.restarPuntos()
        assert.that(puntuacionMngr.puntos() >= 0)
    }

    test "reiniciarAtributos deja valores iniciales" {
        puntuacionMngr.sumarPuntos()
        puntuacionMngr.reiniciarAtributos()
        assert.equals(0, puntuacionMngr.puntos())
        assert.equals(0, puntuacionMngr.jugadas())
        assert.equals(false, puntuacionMngr.bonusActivo())
    }

    
}

describe "Tests de tableroYCartas" {
    test "crearCartas genera el número correcto de cartas y celdas" {
        tableroSiete.reiniciarAtributos()
        tableroSiete.generarTodasCartaNumero()
        tableroSiete.crearCartas(3, true)
        assert.equals(6, tableroSiete.cartas().size())
        assert.equals(6, tableroSiete.celdas().size())
    }

    test "reiniciarAtributos deja todo vacío y resetea cartaNumero" {
        tableroSiete.generarTodasCartaNumero()
        tableroSiete.crearCartas(2, true)
        tableroSiete.reiniciarAtributos()
        assert.equals(0, tableroSiete.cartas().size())
        assert.equals(0, tableroSiete.celdas().size())
        assert.equals(0, tableroSiete.cartaNumero().size())
    }

    test "carta da vuelta y muestra el diseño" {
        const carta = new CartaDibujo(id=1)
        carta.voltear()
        assert.that(carta.esVisible())
        carta.voltear()
        assert.notThat(carta.esVisible())
    }

    test "CartaTexto muestra imagen/nombre correcto" {
        const carta = new CartaTexto(id=2)
        carta.voltear()
        assert.equals("SpriteT2.png", carta.image())
    }

    test "CartaTexto debe lanzar excepcion con id invalido" {
        assert.throwsException({
            const carta = new CartaTexto(id=99)
            carta.voltear()
            carta.nombreDibujo()
        })
    }
}

